# ──────────────────────────────────────────────────────────
# NEXUS — Environment Configuration
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────

# ── Default Admin Credentials ──
# Used to seed the admin user on first database creation.
# Change these BEFORE the first run. After the database is
# created, changing these values has no effect (the user is
# already in the database). Use the UI to manage users then.
APP_USERNAME=admin
APP_PASSWORD=admin123

# ── OpenRouter AI API Key ──
# Get a free key at https://openrouter.ai/keys
# Without this key, AI features fall back to rule-based mode.
OPENROUTER_API_KEY=sk-or-v1-your-api-key-here

# ── Optional: Server Configuration ──
NEXUS_PORT=8080
NEXUS_DB_PATH=/app/data/nexus_data.db
NEXUS_INIT_FULLNAME=Administrator
NEXUS_INIT_EMAIL=
